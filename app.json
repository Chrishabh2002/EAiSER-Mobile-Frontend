{
  "expo": {
    "name": "EAiSER AI",
    "slug": "eaiser-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eaiser",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eaiser.app"
    },
    "android": {
      "package": "com.eaiser.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}